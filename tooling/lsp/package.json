{
  "name": "cx-language-server",
  "version": "0.1.0",
  "description": "Language server for the CX markup/configuration language",
  "main": "out/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "node out/server.js --stdio"
  },
  "bin": {
    "cx-language-server": "out/server.js"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.0.0"
  }
}
