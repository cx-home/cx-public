{
  "name": "tree-sitter-cx",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the CX markup language",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "cx"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.17.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.20.8"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "build": "node-gyp rebuild",
    "test": "tree-sitter test"
  },
  "tree-sitter": [
    {
      "scope": "source.cx",
      "file-types": ["cx"],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ]
}
